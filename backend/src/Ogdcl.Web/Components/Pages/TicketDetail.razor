@page "/tickets/{Id:int}"
@inherits AppPage

<PageTitle>Complaint — OGDCL</PageTitle>

@if (Error is not null)
{
    <div class="alert alert-error">@Error</div>
}

@if (_t is null)
{
    @if (!Loading)
    {
        <div class="empty">Complaint not found or not accessible.</div>
    }
}
else
{
    <div class="page-head">
        <div>
            <h1>@_t.TicketNumber · @_t.Title</h1>
            <div class="page-sub">
                <span class="badge s-@_t.Status.ToString().ToLower()">@Pretty(_t.Status)</span>
                <span class="badge p-@_t.Severity.ToString().ToLower()">@_t.Severity</span>
                @if (_t.IsOverdue)
                {
                    <span class="badge badge-overdue">⚠ Overdue</span>
                }
            </div>
        </div>
        <a class="btn btn-secondary" href="/tickets"><Icon Name="arrow-left" Size="16" /> Back</a>
    </div>

    @if (_t.IsOverdue)
    {
        <div class="alert alert-overdue">⚠ This complaint ran past its severity deadline and was auto-escalated. Please prioritise it.</div>
    }

    <div class="card">
        <div class="meta-grid">
            <div class="meta-item"><div class="k">Category</div><div class="v">@_t.Category</div></div>
            <div class="meta-item"><div class="k">Department</div><div class="v">@(_t.Department ?? "—")</div></div>
            <div class="meta-item"><div class="k">Raised by</div><div class="v">@_t.CreatedBy</div></div>
            <div class="meta-item"><div class="k">Assigned to</div><div class="v">@(_t.AssignedTo ?? "Unassigned")</div></div>
            <div class="meta-item"><div class="k">Created</div><div class="v">@_t.CreatedAt.ToLocalTime().ToString("HH:mm dd MMM yyyy")</div></div>
        </div>
        <p style="margin:14px 0 0; white-space:pre-wrap">@_t.Description</p>
        @if (_t.RecommendedHandler is not null)
        {
            <div style="margin-top:12px">
                <span class="recommend"><Icon Name="check" Size="14" /> Suggested handler: @_t.RecommendedHandler</span>
                <span class="hint"> — advisory only; a handler still has to accept.</span>
            </div>
        }
        @if (_t.Attachments.Count > 0)
        {
            <div style="margin-top:14px">
                <div class="k hint">Attachments</div>
                @foreach (var a in _t.Attachments)
                {
                    <div><a href="@AttachmentUrl(a.Id)" target="_blank">📎 @a.FileName</a> <span class="hint">(@FormatSize(a.SizeBytes))</span></div>
                }
            </div>
        }
    </div>

    @* ---- urgent approval (admins) ---- *@
    @if (_t.Status == TicketStatus.PendingApproval && Auth.IsAdmin)
    {
        <div class="card">
            <h2>Approval needed</h2>
            <p class="hint">This urgent complaint needs your approval before handlers can pick it up.</p>
            <label>Reason (required if declining)</label>
            <input type="text" @bind="_reason" placeholder="e.g. Not actually urgent — reclassify" />
            <div class="inline" style="margin-top:12px">
                <button class="btn btn-sm" @onclick="ApproveAsync"><Icon Name="check" Size="16" /> Approve</button>
                <button class="btn btn-sm btn-danger" @onclick="DeclineAsync">Decline</button>
            </div>
        </div>
    }

    @* ---- handler accept / reject ---- *@
    @if (_t.Status == TicketStatus.Open && Auth.IsHandler && SameDept)
    {
        <div class="card">
            <h2>This complaint is open</h2>
            <p class="hint">Accept it to take ownership, or pass it on so it stays available to your colleagues.</p>
            <label>Reason for passing (optional)</label>
            <input type="text" @bind="_reason" placeholder="Why is this not for you?" />
            <div class="inline" style="margin-top:12px">
                <button class="btn btn-sm" @onclick="AcceptAsync"><Icon Name="check" Size="16" /> Accept</button>
                <button class="btn btn-sm btn-secondary" @onclick="RejectAsync">Pass on</button>
            </div>
        </div>
    }

    @* ---- work / close actions ---- *@
    @if (ShowWorkActions)
    {
        <div class="card">
            <h2>Actions</h2>
            <label>Note (optional, recorded in the history)</label>
            <input type="text" @bind="_note" placeholder="e.g. Replaced the cable" />
            <div class="inline" style="margin-top:12px; flex-wrap:wrap">
                @if (CanWork && _t.Status == TicketStatus.Assigned)
                {
                    <button class="btn btn-sm" @onclick="@(() => MoveAsync(TicketStatus.InProgress))">Start work</button>
                }
                @if (CanWork && _t.Status == TicketStatus.InProgress)
                {
                    <button class="btn btn-sm" @onclick="@(() => MoveAsync(TicketStatus.Resolved))">Mark resolved</button>
                }
                @if (_t.Status == TicketStatus.Resolved && (IsCreator || CanWork))
                {
                    <button class="btn btn-sm" @onclick="@(() => MoveAsync(TicketStatus.Closed))">Close complaint</button>
                }
                @if (_t.Status == TicketStatus.Resolved && (IsCreator || Auth.IsAdmin))
                {
                    <button class="btn btn-sm btn-secondary" @onclick="@(() => MoveAsync(TicketStatus.InProgress))">Reopen</button>
                }
            </div>
        </div>
    }

    @if (IsCreator && _t.Status is TicketStatus.Resolved or TicketStatus.Closed && _t.Feedback is null)
    {
        <div class="card">
            <h2>How was this handled?</h2>
            <div class="inline" style="max-width:520px">
                <select @bind="_rating">
                    <option value="5">★★★★★ Excellent</option>
                    <option value="4">★★★★ Good</option>
                    <option value="3">★★★ Okay</option>
                    <option value="2">★★ Poor</option>
                    <option value="1">★ Very poor</option>
                </select>
                <input type="text" @bind="_feedbackComment" placeholder="Optional comment" />
                <button class="btn btn-sm" @onclick="FeedbackAsync">Send</button>
            </div>
        </div>
    }

    @if (_t.Feedback is not null)
    {
        <div class="card">
            <h2>Feedback</h2>
            <div>@(new string('★', _t.Feedback.Rating))@(new string('☆', 5 - _t.Feedback.Rating)) — @(_t.Feedback.Comment ?? "no comment")</div>
        </div>
    }

    <div class="card">
        <h2>History</h2>
        <ul class="timeline">
            @foreach (var h in Enumerable.Reverse(_t.StatusHistory))
            {
                <li>
                    <div><strong>@(h.FromStatus is null ? "Submitted" : $"{Pretty(h.FromStatus.Value)} → {Pretty(h.ToStatus)}")</strong> · @h.ChangedBy</div>
                    @if (!string.IsNullOrWhiteSpace(h.Note))
                    {
                        <div class="hint">@h.Note</div>
                    }
                    <div class="when">@h.ChangedAt.ToLocalTime().ToString("HH:mm dd MMM yyyy")</div>
                </li>
            }
        </ul>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private TicketDto? _t;
    private string _note = "";
    private string _reason = "";
    private string _feedbackComment = "";
    private int _rating = 5;

    private bool IsCreator => _t?.CreatedById == Auth.User?.Id;
    private bool IsAssigned => _t?.AssignedToId == Auth.User?.Id;
    private bool CanWork => IsAssigned || Auth.IsAdmin;
    private bool SameDept => _t?.Department is not null && _t.Department == Auth.User?.Department;
    private bool ShowWorkActions => _t is not null
        && _t.Status is TicketStatus.Assigned or TicketStatus.InProgress or TicketStatus.Resolved
        && (IsCreator || CanWork);

    private string AttachmentUrl(int attachmentId) =>
        $"{Api.BaseUrl}api/tickets/{Id}/attachments/{attachmentId}?access_token={Auth.Token}";

    protected override async Task LoadAsync() => _t = await Api.GetTicketAsync(Id);

    private async Task ApproveAsync() => await Try(async () => _t = await Api.ApproveTicketAsync(Id));
    private async Task DeclineAsync()
    {
        if (string.IsNullOrWhiteSpace(_reason)) { Error = "Please give a reason for declining."; return; }
        await Try(async () => { _t = await Api.RejectApprovalAsync(Id, _reason); _reason = ""; });
    }

    private async Task AcceptAsync() => await Try(async () => _t = await Api.AcceptTicketAsync(Id));
    private async Task RejectAsync() => await Try(async () => { _t = await Api.RejectTicketAsync(Id, string.IsNullOrWhiteSpace(_reason) ? null : _reason); _reason = ""; });

    private async Task MoveAsync(TicketStatus to) => await Try(async () =>
    {
        _t = await Api.UpdateTicketStatusAsync(Id, to, string.IsNullOrWhiteSpace(_note) ? null : _note);
        _note = "";
    });

    private async Task FeedbackAsync() => await Try(async () =>
        _t = await Api.AddFeedbackAsync(Id, _rating, string.IsNullOrWhiteSpace(_feedbackComment) ? null : _feedbackComment));

    private static string Pretty(TicketStatus s) => s switch
    {
        TicketStatus.PendingApproval => "Pending approval",
        TicketStatus.InProgress => "In progress",
        _ => s.ToString(),
    };

    private static string FormatSize(long bytes) =>
        bytes < 1024 ? $"{bytes} B" : bytes < 1024 * 1024 ? $"{bytes / 1024.0:F1} KB" : $"{bytes / (1024.0 * 1024):F1} MB";
}

@page "/"
@inherits AppPage

<PageTitle>Dashboard — OGDCL</PageTitle>

<div class="page-head">
    <div>
        <h1>Dashboard</h1>
        <div class="page-sub">Welcome back, @Auth.User?.DisplayName</div>
    </div>
</div>

@if (Error is not null)
{
    <div class="alert alert-error">@Error</div>
}

@if (Loading)
{
    <Skeleton Variant="stats" Count="4" />
}
else
{
    <div class="stat-grid">
        @if (Auth.IsEmployee)
        {
            <div class="stat">
                <div class="stat-icon"><Icon Name="ticket" /></div>
                <div class="stat-value">@_myOpenTickets</div>
                <div class="stat-label">My open complaints</div>
            </div>
        }
        @if (Auth.IsHandler)
        {
            <div class="stat">
                <div class="stat-icon"><Icon Name="inbox" /></div>
                <div class="stat-value">@_available.Count</div>
                <div class="stat-label">Available to accept</div>
            </div>
            <div class="stat">
                <div class="stat-icon"><Icon Name="ticket" /></div>
                <div class="stat-value">@_assigned.Count</div>
                <div class="stat-label">In my queue</div>
            </div>
        }
        @if (Auth.IsAdmin)
        {
            <div class="stat">
                <div class="stat-icon"><Icon Name="clock" /></div>
                <div class="stat-value">@_approvals.Count</div>
                <div class="stat-label">Awaiting my approval</div>
            </div>
            <div class="stat">
                <div class="stat-icon"><Icon Name="grid" /></div>
                <div class="stat-value">@_totalTickets</div>
                <div class="stat-label">Complaints @(Auth.IsFloorAdmin ? "in my dept" : "all time")</div>
            </div>
        }
        @if (Auth.IsSecurity)
        {
            <div class="stat">
                <div class="stat-icon"><Icon Name="clock" /></div>
                <div class="stat-value">@_pending.Count</div>
                <div class="stat-label">Expected visitors</div>
            </div>
            <div class="stat">
                <div class="stat-icon"><Icon Name="shield" /></div>
                <div class="stat-value">@_active.Count</div>
                <div class="stat-label">Visitors on site</div>
            </div>
        }
        else
        {
            <div class="stat">
                <div class="stat-icon"><Icon Name="users" /></div>
                <div class="stat-value">@_myVisits.Count(v => v.Status is VisitStatus.Registered or VisitStatus.Arrived)</div>
                <div class="stat-label">My upcoming/active visits</div>
            </div>
        }
        <div class="stat">
            <div class="stat-icon"><Icon Name="bell" /></div>
            <div class="stat-value">@_unread.Count</div>
            <div class="stat-label">Unread notifications</div>
        </div>
    </div>

    <div class="card">
        <h2>Quick actions</h2>
        <div class="inline" style="flex-wrap:wrap">
            @if (Auth.IsEmployee)
            {
                <a class="btn btn-sm" href="/tickets/new"><Icon Name="plus" Size="16" /> Submit a complaint</a>
            }
            <a class="btn btn-sm btn-secondary" href="/tickets"><Icon Name="ticket" Size="16" /> Open Help Desk</a>
            <a class="btn btn-sm btn-secondary" href="/visitors"><Icon Name="users" Size="16" /> Register a visitor</a>
            @if (Auth.IsSecurity)
            {
                <a class="btn btn-sm btn-secondary" href="/gate"><Icon Name="shield" Size="16" /> Open gate desk</a>
            }
        </div>
    </div>

    <div class="card">
        <h2>Recent notifications</h2>
        @if (_unread.Count == 0)
        {
            <div class="empty">Nothing unread. All caught up.</div>
        }
        else
        {
            @foreach (var n in _unread.Take(6))
            {
                <div class="notif unread">
                    <div>
                        <div class="notif-title">@n.Title</div>
                        <div class="notif-body">@n.Body</div>
                    </div>
                    <div class="notif-time">@n.CreatedAt.ToLocalTime().ToString("HH:mm dd MMM")</div>
                </div>
            }
            <div style="margin-top:10px"><a href="/notifications">View all →</a></div>
        }
    </div>
}

@code {
    private List<TicketSummaryDto> _mine = [];
    private List<TicketSummaryDto> _available = [];
    private List<TicketSummaryDto> _assigned = [];
    private List<TicketSummaryDto> _approvals = [];
    private List<VisitDto> _myVisits = [];
    private List<VisitDto> _pending = [];
    private List<VisitDto> _active = [];
    private List<NotificationDto> _unread = [];
    private int _totalTickets;
    private int _myOpenTickets;

    protected override async Task LoadAsync()
    {
        _myVisits = await Api.GetMyVisitsAsync();
        _unread = await Api.GetNotificationsAsync(unreadOnly: true);

        if (Auth.IsEmployee)
        {
            _mine = await Api.GetMyTicketsAsync();
            _myOpenTickets = _mine.Count(t => t.Status is not (TicketStatus.Closed or TicketStatus.Rejected));
        }

        if (Auth.IsHandler)
        {
            _available = await Api.GetAvailableTicketsAsync();
            _assigned = await Api.GetAssignedTicketsAsync();
        }

        if (Auth.IsSecurity)
        {
            _pending = await Api.GetPendingVisitsAsync();
            _active = await Api.GetActiveVisitsAsync();
        }

        if (Auth.IsAdmin)
        {
            _approvals = await Api.GetPendingApprovalsAsync();
            _totalTickets = (await Api.SearchTicketsAsync(null, 1, 1)).Total;
        }
    }
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    @* Apply the saved theme before first paint to avoid a flash of the wrong theme.
       Falls back to the OS preference on a visitor's first ever load. *@
    <script>
        (function () {
            try {
                var t = localStorage.getItem("ogdcl-theme");
                if (!t) t = (window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches) ? "dark" : "light";
                document.documentElement.setAttribute("data-theme", t);
            } catch (e) { document.documentElement.setAttribute("data-theme", "light"); }
        })();
    </script>
    <link rel="icon" type="image/jpeg" href="assets/ogdcl-logo.jpg" />
    <link rel="stylesheet" href="app.css" />
    <link rel="stylesheet" href="Ogdcl.Web.styles.css" />
    <script src="js/theme.js"></script>
    <HeadOutlet @rendermode="new InteractiveServerRenderMode(prerender: false)" />
</head>

<body>
    @* Prerendering is disabled so ProtectedSessionStorage (JS interop) is
       available from component initialisation onward. *@
    <Routes @rendermode="new InteractiveServerRenderMode(prerender: false)" />
    <script src="_framework/blazor.web.js"></script>
</body>

</html>

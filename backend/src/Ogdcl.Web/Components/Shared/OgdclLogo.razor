@* OGDCL brand mark. The artwork is a real asset file at
   wwwroot/assets/ogdcl-logo.jpg (served at /assets/ogdcl-logo.jpg). Replace that
   file to update the logo everywhere this component is used (sidebar + login);
   no code change needed. *@
<img class="ogdcl-mark" src="assets/ogdcl-logo.jpg" width="@Width" alt="OGDCL logo" />

@code {
    [Parameter] public int Width { get; set; } = 96;
}
